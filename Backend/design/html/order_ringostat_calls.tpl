                                        {elseif $call->status == 'NO ANSWER' && $call->direction == 'out'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_no_answer|escape}"><span class="tag tag-default fn_status_label"><span class="fn_status_icon fn_status_icon_default"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2c-8.072 -.49 -14.51 -6.928 -15 -15a2 2 0 0 1 2 -2" /><path d="M17 3l4 4" /><path d="M21 3l-4 4" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_no_answer|escape}</span></span></span>
                                        {elseif $call->status == 'FAILED'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_failed|escape}"><span class="tag tag-default fn_status_label"><span class="fn_status_icon fn_status_icon_default"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /><path d="M16 4l4 4m0 -4l-4 4" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_failed|escape}</span></span></span>
                                        {elseif $call->status == 'CALLING'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_calling|escape}"><span class="tag tag-info fn_status_label"><span class="fn_status_icon fn_status_icon_info"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /><path d="M15 7l0 .01" /><path d="M18 7l0 .01" /><path d="M21 7l0 .01" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_calling|escape}</span></span></span>
                                        {elseif $call->status == 'IN PROGRESS'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_in_progress|escape}"><span class="tag tag-info fn_status_label"><span class="fn_status_icon fn_status_icon_info"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /><path d="M15 7a2 2 0 0 1 2 2" /><path d="M15 3a6 6 0 0 1 6 6" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_in_progress|escape}</span></span></span>
                                        {elseif $call->status == 'REPEATED'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_repeated|escape}"><span class="tag tag-warning fn_status_label"><span class="fn_status_icon fn_status_icon_warning"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4H9L11 9L8.5 10.5C9.57096 12.6715 11.3285 14.429 13.5 15.5L15 13L20 15V19C20 19.5304 19.7893 20.0391 19.4142 20.4142C19.0391 20.7893 18.5304 21 18 21C14.0993 20.763 10.4202 19.1065 7.65683 16.3432C4.8935 13.5798 3.23705 9.90074 3 6C3 5.46957 3.21071 4.96086 3.58579 4.58579C3.96086 4.21071 4.46957 4 5 4Z" /><path d="M19.3711 8.86713C19.0308 9.29335 18.5803 9.61929 18.068 9.81C17.5558 10.0007 17.001 10.049 16.4632 9.94968C15.9255 9.85036 15.425 9.60718 15.0155 9.24623C14.6061 8.88527 14.303 8.42016 14.1389 7.90077C13.9747 7.38137 13.9557 6.8273 14.0838 6.29796C14.212 5.76862 14.4824 5.28399 14.8662 4.89605C15.25 4.5081 15.7326 4.23147 16.2623 4.09583C17.7306 3.72091 19.2506 4.47338 19.8117 5.87558" /><path d="M20 4V6H18" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_repeated|escape}</span></span></span>
                                        {elseif $call->status == 'BUSY'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_busy|escape}"><span class="tag tag-default fn_status_label"><span class="fn_status_icon fn_status_icon_default"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2c-8.072 -.49 -14.51 -6.928 -15 -15a2 2 0 0 1 2 -2" /><path d="M17 3v5" /><path d="M21 3v5" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_busy|escape}</span></span></span>
                                        {else}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$call->status|escape}"><span class="tag tag-default fn_status_label"><span class="fn_status_icon fn_status_icon_default"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /><path d="M16 4l4 4m0 -4l-4 4" /></svg></span><span class="fn_status_text">{$call->status|escape}</span></span></span>
                                        {/if}
                                    </div>
                                    <div class="fn_ringostat_order_calls_cell fn_ringostat_order_calls_col_rec">
                                        {if $call->employee_fio || $call->department}
                                            <span class="fn_ringostat_order_call_manager fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{if $call->employee_fio}{$call->employee_fio|escape}{if $call->department} · {/if}{/if}{if $call->department}{$call->department|escape}{/if}">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="fn_ringostat_order_call_manager_icon"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0" /><path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2" /></svg>
                                            </span>
                                        {/if}
                                        {if $call->record_url}
                                            <button type="button" class="btn_close fn_open_record_modal fn_ringostat_no_row_click fn_ringostat_order_call_record hint-bottom-right-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__listen|escape}" data-record-href="{$rootUrl}/backend/index.php?controller=Sviat.Ringostat.RingostatCallsAdmin@record&amp;id={$call->id|escape}">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 4v16l13 -8l-13 -8" /></svg>
                                            </button>
                                        {else}
                                            <span class="fn_ringostat_order_calls_no_rec" role="img" aria-label="{$btr->sviat__ringostat__no_record|escape}" title="{$btr->sviat__ringostat__no_record|escape}">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-player-stop" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M5 7a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2l0 -10" /></svg>
                                            </span>
                                        {/if}
                                    </div>
                                </div>
                            {/foreach}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {else}
        <span class="text-muted fn_ringostat_order_calls_empty">{$btr->sviat__ringostat__order_calls_empty|escape}</span>
    {/if}
</div>

