{if $order->id && isset($order->sviat_ringostat_calls)}
{* <link rel="stylesheet" type="text/css" href="{$rootUrl}/Okay/Modules/Sviat/Ringostat/Backend/design/css/ringostat_calls.css" media="screen" /> *}
<div class="fn_ringostat_order_calls_wrap">
    {if $order->sviat_ringostat_calls|@count > 0}
        <div class="fn_ringostat_orders_dropdown fn_ringostat_order_calls_dropdown">
            <div class="fn_ringostat_orders_inner">
                <span class="fn_ringostat_orders_icon fn_ringostat_orders_trigger" title="{$btr->sviat__ringostat__order_calls_hint|escape}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-phone-call"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /><path d="M15 7a2 2 0 0 1 2 2" /><path d="M15 3a6 6 0 0 1 6 6" /></svg>
                </span>
                <div class="fn_ringostat_orders_toggle fn_ringostat_order_calls_toggle">
                    <div class="fn_ringostat_order_calls_table">
                        <div class="fn_ringostat_order_calls_scroll{if $order->sviat_ringostat_calls|@count > 5} fn_ringostat_order_calls_scroll_limited{/if}">
                            {foreach $order->sviat_ringostat_calls as $call}
                                <div class="fn_ringostat_order_calls_row">
                                    <div class="fn_ringostat_order_calls_cell fn_ringostat_order_calls_col_dt">
                                        {if $call->started_at}{$call->started_at|date_format:"%d.%m.%Y %H:%M"}{else}—{/if}
                                    </div>
                                    <div class="fn_ringostat_order_calls_cell fn_ringostat_order_calls_col_status fn_status_cell">
                                        {if $call->status == 'PROPER'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_proper|escape}"><span class="tag tag-success fn_status_label"><span class="fn_status_icon fn_status_icon_success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /><path d="M15 6l2 2l4 -4" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_proper|escape}</span></span></span>
                                        {elseif $call->status == 'ANSWERED'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_answered|escape}"><span class="tag tag-success fn_status_label"><span class="fn_status_icon fn_status_icon_success"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /><path d="M15 6l2 2l4 -4" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_answered|escape}</span></span></span>
                                        {elseif $call->status == 'VOICEMAIL'}
                                            <span class="fn_ringostat_order_status_hint fn_ringostat_no_row_click hint-bottom-middle-t-info-s-small-mobile hint-anim" data-hint="{$btr->sviat__ringostat__status_voicemail|escape}"><span class="tag tag-warning fn_status_label"><span class="fn_status_icon fn_status_icon_warning"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M21 8c-4 0 -7 2 -7 5a3 3 0 0 0 6 0c0 -3 -2.5 -5 -8 -5s-8 2 -8 5a3 3 0 0 0 6 0c0 -3 -3 -5 -7 -5" /></svg></span><span class="fn_status_text">{$btr->sviat__ringostat__status_voicemail|escape}</span></span></span>
